---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Decorations from '../components/Decorations.astro';
import Grass from '../components/Grass.astro';

interface Props {
  title?: string;
  description?: string;
  current?: string;      // 導覽高亮
  siteClass?: string;    // .site 額外 class（404 用 nf-site）
  crawler?: boolean;
  scanlines?: boolean;
  nav?: boolean;         // 是否顯示導覽列（預設 true）
  grass?: boolean;       // 是否顯示底部草皮（首頁用）
}
const {
  title = 'debug.log — 普通人類的觀察日記',
  description = '機器人研究、資安 CTF、強化學習與日文學習筆記。',
  current = '',
  siteClass = '',
  crawler = true,
  scanlines = false,
  nav = true,
  grass = false,
} = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=Noto+Sans+TC:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  {/* 防閃爍：在畫面繪製前先套用儲存的主題 */}
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (t !== 'light' && t !== 'dark') {
          t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.dataset.theme = t;
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <div class={`site ${siteClass} ${grass ? 'has-grass' : ''}`} id="site" data-screen-label={title}>
    {nav && <Nav current={current} />}
    <slot />
    <Footer />
    <Decorations crawler={crawler} scanlines={scanlines} />
    {grass && <Grass />}
  </div>
  <script>
    import { initSite } from '../scripts/site.js';
    // 讓 .site 的 light/dark class 對齊 <html data-theme>
    const root = document.getElementById('site');
    const t = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    root?.classList.add(t);
    initSite();
  </script>
</body>
</html>
