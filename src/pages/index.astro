---
import BaseLayout from '../layouts/BaseLayout.astro';
import Slimo from '../components/Slimo.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, collectTags, collectCategories, catClass, fmtDate } from '../lib/posts';

const posts = await getSortedPosts();
const featured = posts[0];
const rest = posts.slice(1, 7);
const cats = collectCategories(posts);
const tags = collectTags(posts).slice(0, 10);
---
<BaseLayout current="home" grass={true}>
  <header class="hero"><div class="container">
    <p class="px sub fs13 m0">// robotics × security × RL × 日本語</p>
    <h1 class="px herotitle m0">普通人類的觀察日記</h1>
    <p class="sub fs15 m0" style="max-width:560px;line-height:1.8">機器人研究筆記（IDLab / LeRobot / SmolVLA）、資安 CTF writeup、強化學習實作，以及偶爾出現的日文學習心得。</p>
  </div></header>

  <main class="container maingrid">
    <div>
      {featured && (
        <article class="card fcard lift">
          <div class="fx ac jb">
            <span class="fx ac gap8">
              <span class={`chip px ${catClass(featured.data.category)}`}>{featured.data.category}</span>
              <span class="chip px" style="background:var(--chip);color:var(--ink)">最新</span>
            </span>
            <span class="date px">{fmtDate(featured.data.date)}</span>
          </div>
          <h2 class="px ftitle"><a href={`/posts/${featured.slug}/`}>{featured.data.title}</a></h2>
          <p class="excerpt sub">{featured.data.excerpt}</p>
          <div class="fx ac jb mt16">
            <div class="fx ac gap10 wrap">
              {featured.data.tags.map((t) => <span class="tag mono">#{t}</span>)}
            </div>
            <a href={`/posts/${featured.slug}/`} class="px fs13 fw7">閱讀全文 →</a>
          </div>
        </article>
      )}

      <div class="postgrid">
        {rest.map((p) => <PostCard post={p} />)}
      </div>

      <div class="tc" style="margin-top:36px"><a href="/posts/" class="morebtn px lift">更多文章 →</a></div>
    </div>

    <aside class="side">
      <div class="card sidecard">
        <div class="fx ac gap16">
          <Slimo sprite="slime" size={72} class="noshrink" label="Slimo 頭像" />
          <div>
            <p class="px fs16 fw7 m0">阿哲 / bit.o</p>
            <p class="sub fs12 m0" style="margin-top:4px">機器人研究生 @ IDLab</p>
          </div>
        </div>
        <p class="sub fs13 mt12 m0" style="line-height:1.8">白天讓機械手臂學抓東西，晚上解 pwn 題。相信像素跟梯度都能下降到對的地方。</p>
        <div class="fx ac gap10 mt12 px fs13"><a href="#">GitHub</a><span class="sub">/</span><a href="#">RSS</a><span class="sub">/</span><a href="#">Email</a></div>
      </div>

      <div class="card sidecard">
        <h4 class="px sidetitle">分類</h4>
        <div>
          {cats.map((c) => (
            <div class="catrow fx ac jb">
              <a href="/posts/" class="fx ac gap10"><span class="sq" style={`background:${{'c-robo':'#7EE8C7','c-ctf':'#FF8A8A','c-rl':'#FFC145','c-jp':'#C4B5FD'}[c.cls]}`}></span>{c.name}</a>
              <span class="count mono">{c.n}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="card sidecard">
        <h4 class="px sidetitle">標籤</h4>
        <div class="fx wrap gap8">
          {tags.map((t) => <span class="tagchip mono">{t}</span>)}
        </div>
      </div>
    </aside>
  </main>
</BaseLayout>
